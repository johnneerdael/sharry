# Copy this file to `.env` and fill in values.
# `.env` is gitignored; `.env.template` is tracked as the canonical list.
#
# Variables here are consumed BOTH by docker-compose (for interpolation)
# AND by sharry.conf via HOCON's ${VAR} substitution (since we pass them
# to the container via env_file).

# --- Database ---------------------------------------------------------------
POSTGRES_USER=dbuser
POSTGRES_PASSWORD=change-me
POSTGRES_DB=dbname

# --- Sharry (Netskope Secure File Transfer) ---------------------------------
# Public URL your users will hit (set to whatever hostname Caddy serves).
SHARRY_BASE_URL=http://localhost:9090

# Bootstrap login. Leave true for the first start so you can log in as
# admin/admin, create real accounts, then flip to false and redeploy.
SHARRY_FIXED_ENABLED=true

# Password required to generate invitation keys when signup.mode=invite.
SHARRY_INVITE_PASSWORD=change-me

# Signup mode: "open" | "invite" | "closed"
SHARRY_SIGNUP_MODE=invite
